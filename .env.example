LOCAL_CHAT_OLLAMA_BASE_URL=http://localhost:11434
LOCAL_CHAT_DEFAULT_MODEL=qwen3.6:35b
LOCAL_CHAT_SYSTEM_PROMPT=你是一个本地中文助手，请用中文回答，结构清晰。
LOCAL_CHAT_MAX_CONTEXT_MESSAGES=40
LOCAL_CHAT_MAX_FILE_CHARS=30000
